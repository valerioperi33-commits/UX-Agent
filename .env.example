# .env.example — modello di configurazione da COPIARE in .env
# ------------------------------------------------------------
# Sul vostro Mac:   cp .env.example .env
# Poi modificate i valori qui sotto se serve. Il file .env NON va su GitHub
# (è nel .gitignore), così ogni Mac può avere le sue impostazioni.

# Modello vision usato via Ollama.
#   16 GB di RAM o piu' -> qwen2.5vl:7b   (consigliato)
#    8 GB di RAM        -> qwen2.5vl:7b funziona ma e' LENTO (chiudete le altre app);
#                          in alternativa, piu' leggeri:  llava:7b   oppure  qwen2.5vl:3b
MODELLO_VISION=qwen2.5vl:7b

# Cartella dove mettete gli screenshot da analizzare.
CARTELLA_SCREEN=screens

# Cartella dove salvare i report generati ('.' = cartella del progetto).
CARTELLA_REPORT=.

# Lingua del testo per l'OCR (Tesseract), usata nella Fase OCR.
#   ita = italiano, eng = inglese, ita+eng = entrambi.
OCR_LINGUA=ita+eng

# (Opzionale) Indirizzo del server Ollama. Lasciate commentato per il default locale.
# OLLAMA_HOST=http://127.0.0.1:11434
