# .env.example — modello di configurazione da COPIARE in .env
# ------------------------------------------------------------
# Sul vostro Mac:   cp .env.example .env
# Poi modificate i valori qui sotto se serve. Il file .env NON va su GitHub
# (è nel .gitignore), così ogni Mac può avere le sue impostazioni.

# Modello vision usato via Ollama. Compromesso VELOCITA' / QUALITA':
#   qwen2.5vl:3b  -> VELOCE (consigliato per la dimostrazione all'esame)
#   qwen2.5vl:7b  -> giudizio piu' ricco ma piu' LENTO (serve piu' RAM)
#   8 GB di RAM   -> restate su 3b; alternativa piu' leggera ancora: llava:7b
MODELLO_VISION=qwen2.5vl:3b

# --- Velocita' (per far stare l'analisi in pochi secondi) ---
# Lato massimo in pixel a cui ridurre l'immagine prima di darla al modello (0 = mai).
LATO_MAX_MODELLO=1024
# Tetto ai token generati dal modello (risposta corta = piu' veloce).
MAX_TOKEN_RISPOSTA=320
# Quanto Ollama tiene il modello in memoria tra una richiesta e l'altra.
OLLAMA_KEEP_ALIVE=30m

# Porta dell'interfaccia grafica. NON usate la 5000: su macOS e' del Ricevitore AirPlay.
PORTA=5001

# Cartella dove mettete gli screenshot da analizzare.
CARTELLA_SCREEN=screens

# Cartella dove salvare i report generati ('.' = cartella del progetto).
CARTELLA_REPORT=.

# Lingua del testo per l'OCR (Tesseract): ita / eng / ita+eng.
OCR_LINGUA=ita+eng

# (Opzionale) Indirizzo del server Ollama. Lasciate commentato per il default locale.
# OLLAMA_HOST=http://127.0.0.1:11434
